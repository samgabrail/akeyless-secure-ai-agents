{"type":"excalidraw","version":2,"source":"mcp","elements":[{"type":"text","id":"title","x":150,"y":0,"text":"AI Agent Identity Lifecycle","fontSize":28,"strokeColor":"#1e1e1e","fontFamily":1,"width":380,"height":34},{"type":"rectangle","id":"bg","x":0,"y":50,"width":780,"height":420,"backgroundColor":"#dbe4ff","fillStyle":"solid","roundness":{"type":3},"strokeColor":"transparent","strokeWidth":0,"opacity":30},{"type":"rectangle","id":"p1","x":40,"y":90,"width":320,"height":130,"backgroundColor":"#a5d8ff","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2},{"type":"text","id":"p1n","x":70,"y":100,"text":"1. PROVISIONING","fontSize":20,"strokeColor":"#2563eb","fontFamily":1,"width":220,"height":26},{"type":"text","id":"p1d","x":70,"y":135,"text":"Assign unique, policy-bound\nidentity to verified agent","fontSize":16,"strokeColor":"#1e1e1e","fontFamily":1,"width":260,"height":44},{"type":"arrow","id":"a1","x":360,"y":155,"width":80,"height":0,"points":[[0,0],[80,0]],"strokeColor":"#4a9eed","strokeWidth":3,"endArrowhead":"arrow"},{"type":"rectangle","id":"p2","x":440,"y":90,"width":320,"height":130,"backgroundColor":"#d0bfff","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2},{"type":"text","id":"p2n","x":460,"y":100,"text":"2. AUTHORIZATION & SCOPING","fontSize":18,"strokeColor":"#6d28d9","fontFamily":1,"width":310,"height":24},{"type":"text","id":"p2d","x":460,"y":135,"text":"Define least-privilege access\ntask-specific and time-bound","fontSize":16,"strokeColor":"#1e1e1e","fontFamily":1,"width":270,"height":44},{"type":"arrow","id":"a2","x":600,"y":220,"width":0,"height":60,"points":[[0,0],[0,60]],"strokeColor":"#8b5cf6","strokeWidth":3,"endArrowhead":"arrow"},{"type":"rectangle","id":"p3","x":440,"y":280,"width":320,"height":130,"backgroundColor":"#b2f2bb","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2},{"type":"text","id":"p3n","x":460,"y":290,"text":"3. RUNTIME ENFORCEMENT","fontSize":18,"strokeColor":"#15803d","fontFamily":1,"width":290,"height":24},{"type":"text","id":"p3d","x":460,"y":325,"text":"Monitor agent behavior to\nensure it stays within\ngranted permissions","fontSize":16,"strokeColor":"#1e1e1e","fontFamily":1,"width":240,"height":60},{"type":"arrow","id":"a3","x":440,"y":345,"width":-80,"height":0,"points":[[0,0],[-80,0]],"strokeColor":"#22c55e","strokeWidth":3,"endArrowhead":"arrow"},{"type":"rectangle","id":"p4","x":40,"y":280,"width":320,"height":130,"backgroundColor":"#ffd8a8","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2},{"type":"text","id":"p4n","x":70,"y":290,"text":"4. DEPROVISIONING","fontSize":20,"strokeColor":"#b45309","fontFamily":1,"width":240,"height":26},{"type":"text","id":"p4d","x":70,"y":325,"text":"Revoke access, invalidate\ncredentials, and preserve\nevidence","fontSize":16,"strokeColor":"#1e1e1e","fontFamily":1,"width":240,"height":60},{"type":"arrow","id":"a4","x":200,"y":280,"width":0,"height":-60,"points":[[0,0],[0,-60]],"strokeColor":"#f59e0b","strokeWidth":3,"endArrowhead":"arrow"}],"appState":{"viewBackgroundColor":"#ffffff"}}
